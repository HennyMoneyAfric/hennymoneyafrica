<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="HennyMoney Afric official portal for music, streaming, social media, products, and income opportunities." />
  <title>HennyMoney Afric | Official Portal</title>
  <link rel="icon" href="icon-192.png" />
  <style>
    :root{
      --bg:#081121;
      --bg2:#0d1830;
      --card:#121d38;
      --card2:#1a2748;
      --text:#f5f7ff;
      --muted:#b8c3e3;
      --accent:#8b5cf6;
      --accent2:#19c37d;
      --line:rgba(255,255,255,.08);
      --gold:#d8b56a;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      background:linear-gradient(180deg,var(--bg),var(--bg2) 55%,#091120);
      color:var(--text);
      line-height:1.6;
    }
    a{text-decoration:none;color:inherit}
    img{max-width:100%;display:block}
    .container{width:min(1120px,92%);margin:auto}

    .site-header{
      position:sticky;
      top:0;
      z-index:100;
      background:rgba(8,17,33,.88);
      backdrop-filter:blur(10px);
      border-bottom:1px solid var(--line);
    }
    .nav-wrap{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:18px;
      padding:14px 0;
    }
    .logo{
      display:flex;
      align-items:center;
      gap:12px;
      font-weight:800;
      font-size:1.08rem;
    }
    .logo img{
      width:44px;
      height:44px;
      border-radius:12px;
      object-fit:cover;
      border:1px solid rgba(255,255,255,.12);
      box-shadow:0 6px 18px rgba(0,0,0,.25);
      background:#0b1224;
    }
    .logo span{color:var(--text)}

    .nav{
      display:flex;
      gap:16px;
      flex-wrap:wrap;
    }
    .nav a{
      color:var(--muted);
      font-size:.95rem;
    }
    .nav a:hover{color:var(--text)}

    .hero{
      padding:72px 0 50px;
    }
    .hero-grid{
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:28px;
      align-items:center;
    }
    .eyebrow{
      color:var(--accent2);
      text-transform:uppercase;
      letter-spacing:.08em;
      font-size:.82rem;
      font-weight:700;
    }
    h1{
      font-size:clamp(2.3rem,5vw,4.2rem);
      line-height:1.05;
      margin:10px 0 16px;
    }
    h2{
      font-size:clamp(1.6rem,3vw,2.3rem);
      margin:0 0 10px;
    }
    h3{margin-top:0}
    .lead,.section-copy{
      color:var(--muted);
      font-size:1.02rem;
    }

    .hero-actions,.link-grid,.support-grid,.social-grid{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
    }

    .btn{
      display:inline-block;
      padding:13px 18px;
      border-radius:14px;
      font-weight:700;
      border:1px solid var(--line);
    }
    .btn-primary{
      background:linear-gradient(135deg,var(--accent),#a855f7);
      border:none;
    }
    .btn-secondary{
      background:transparent;
    }

    .hero-card,.card,.contact-card,.panel{
      background:linear-gradient(180deg,var(--card),var(--card2));
      border:1px solid var(--line);
      border-radius:22px;
      padding:24px;
      box-shadow:0 10px 30px rgba(0,0,0,.22);
    }

    .hero-brand{
      display:grid;
      gap:18px;
    }
    .hero-logo{
      width:min(100%,360px);
      margin:auto;
      border-radius:24px;
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 18px 40px rgba(0,0,0,.35);
      background:#0a101d;
      padding:12px;
    }

    .badge{
      display:inline-block;
      background:rgba(25,195,125,.12);
      color:#8cf0c0;
      border:1px solid rgba(25,195,125,.18);
      padding:6px 10px;
      border-radius:999px;
      font-size:.78rem;
      font-weight:700;
      margin-bottom:12px;
    }

    .hero-card ul{
      padding-left:18px;
      color:var(--muted);
    }

    .section{
      padding:58px 0;
    }
    .alt{
      background:rgba(255,255,255,.02);
    }
    .section-tag{
      color:var(--accent2);
      text-transform:uppercase;
      letter-spacing:.08em;
      font-size:.8rem;
      font-weight:700;
      margin-bottom:8px;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
      margin-top:20px;
    }
    .card p,.panel p{
      color:var(--muted);
    }

    .platforms{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:18px;
      margin-top:18px;
    }

    .pill{
      display:inline-block;
      padding:10px 14px;
      border-radius:12px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
      color:var(--text);
      font-weight:700;
    }

    .income-grid,.contact-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:22px;
      align-items:start;
    }

    .contact-card,.panel{
      display:grid;
      gap:14px;
    }

    .contact-card a,.link-grid a,.support-grid a,.social-grid a{
      padding:14px 16px;
      background:rgba(255,255,255,.03);
      border:1px solid var(--line);
      border-radius:14px;
      color:var(--text);
      font-weight:600;
    }

    .mini{
      color:var(--muted);
      font-size:.92rem;
    }

    .site-footer{
      border-top:1px solid var(--line);
      padding:22px 0;
      margin-top:10px;
    }

    .footer-wrap{
      display:flex;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
      color:var(--muted);
    }

    @media (max-width: 860px){
      .hero-grid,.cards,.platforms,.income-grid,.contact-grid{
        grid-template-columns:1fr;
      }
      .nav-wrap{
        flex-direction:column;
        align-items:flex-start;
      }
      .hero{
        padding-top:42px;
      }
      .logo img{
        width:40px;
        height:40px;
      }
    }
  </style>
</head>
